#!/usr/bin/env bash
set -euo pipefail

if [[ $# -gt 1 ]]; then
    echo "Usage: $0 [source_dir]"
    echo "Optional env override: PULLH20_SOURCE_DIR=/path/to/H20/H20"
    exit 1
fi

PROJECT_DIR="$(pwd -P)"
TARGET_DIR="${PROJECT_DIR}/H20"
PRESERVE_PROJECT_DIR_REGEX='^[0-9]+-.*$'
PRESERVE_PROJECT_DIR_DISPLAY='/[0-9]+-.*/'

declare -a RSYNC_EXCLUDES=(--exclude="/Extras/pullh20" --exclude="__pycache__/" --exclude="*.pyc")
declare -a PRESERVED_DIR_NAMES=()
declare -a STATIC_PRESERVE_IF_PRESENT=("UserDocs" "Reviews" "RawPrompts")

resolve_script_path() {
    local script_path="${BASH_SOURCE[0]}"
    local resolved_path=""
    local script_dir=""
    local link_target=""
    local hop_count=0

    if [[ "${script_path}" != */* ]]; then
        resolved_path="$(command -v "${script_path}" 2>/dev/null || true)"
        if [[ -n "${resolved_path}" ]]; then
            script_path="${resolved_path}"
        fi
    fi

    while :; do
        if [[ "${script_path}" != /* ]]; then
            script_path="${PWD}/${script_path}"
        fi

        script_dir="$(cd "$(dirname "${script_path}")" && pwd -P)"
        script_path="${script_dir}/$(basename "${script_path}")"

        if [[ ! -L "${script_path}" ]]; then
            printf '%s\n' "${script_path}"
            return 0
        fi

        hop_count=$((hop_count + 1))
        if [[ ${hop_count} -gt 40 ]]; then
            echo "Too many symlink levels resolving ${BASH_SOURCE[0]}" >&2
            return 1
        fi

        link_target="$(readlink "${script_path}")"
        if [[ "${link_target}" == /* ]]; then
            script_path="${link_target}"
        else
            script_path="${script_dir}/${link_target}"
        fi
    done
}

SCRIPT_PATH="$(resolve_script_path)"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd -P)"
SCRIPT_SOURCE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd -P)"

default_source_dir() {
    local home_source_dir=""

    if [[ -n "${HOME:-}" ]]; then
        home_source_dir="${HOME}/PROJECTS/H20/H20"
        if [[ -d "${home_source_dir}" ]]; then
            printf '%s\n' "${home_source_dir}"
            return 0
        fi
    fi

    if [[ -d "${SCRIPT_SOURCE_DIR}" && "${SCRIPT_SOURCE_DIR}" != "${TARGET_DIR}" ]]; then
        printf '%s\n' "${SCRIPT_SOURCE_DIR}"
        return 0
    fi

    if [[ -n "${home_source_dir}" ]]; then
        printf '%s\n' "${home_source_dir}"
    else
        printf '%s\n' "${SCRIPT_SOURCE_DIR}"
    fi
}

SOURCE_DIR="${1:-${PULLH20_SOURCE_DIR:-$(default_source_dir)}}"

require_project_dir() {
    if [[ -e "${PROJECT_DIR}/.git" ]]; then
        return 0
    fi

    echo "Current directory must be a git project root containing .git: ${PROJECT_DIR}"
    exit 1
}

path_is_preserved() {
    local rel_path="$1"
    local first_component="${rel_path%%/*}"
    local preserved_dir=""

    if [[ ${#PRESERVED_DIR_NAMES[@]} -eq 0 ]]; then
        return 1
    fi

    for preserved_dir in "${PRESERVED_DIR_NAMES[@]}"; do
        if [[ "${first_component}" == "${preserved_dir}" ]]; then
            return 0
        fi
    done

    return 1
}

path_is_generated_cache() {
    local rel_path="$1"

    if [[ "${rel_path}" == *__pycache__/* || "${rel_path}" == *.pyc ]]; then
        return 0
    fi

    return 1
}

path_is_excluded_payload_file() {
    local rel_path="$1"

    if [[ "${rel_path}" == "Extras/pullh20" ]]; then
        return 0
    fi

    return 1
}

path_in_list() {
    local needle="$1"
    shift

    local entry=""
    for entry in "$@"; do
        if [[ "${entry}" == "${needle}" ]]; then
            return 0
        fi
    done

    return 1
}

add_preserved_dir() {
    local dir_name="$1"

    if [[ ${#PRESERVED_DIR_NAMES[@]} -gt 0 ]] && path_in_list "${dir_name}" "${PRESERVED_DIR_NAMES[@]}"; then
        return 0
    fi

    PRESERVED_DIR_NAMES+=("${dir_name}")
    RSYNC_EXCLUDES+=(--exclude="/${dir_name}/")
}

make_temp_file() {
    if mktemp "${TMPDIR:-/tmp}/pullh20.XXXXXX" 2>/dev/null; then
        return
    fi

    mktemp -t pullh20
}

report_sync_results() {
    local dry_run_file="$1"
    local line=""
    local path=""
    local item=""
    local update_type=""
    local file_type=""
    local rel_path=""
    local -a changed_paths=()

    while IFS= read -r line || [[ -n "${line}" ]]; do
        if [[ "${line}" =~ ^\*deleting[[:space:]]+(.+)$ ]]; then
            path="${BASH_REMATCH[1]}"
            echo "[deleted] ${path}"
            continue
        fi

        if [[ "${line}" =~ ^([^[:space:]]+)[[:space:]]+(.+)$ ]]; then
            item="${BASH_REMATCH[1]}"
            path="${BASH_REMATCH[2]}"
            update_type="${item:0:1}"
            file_type="${item:1:1}"

            case "${update_type}" in
                '>' | 'c' | 'h')
                    if [[ "${path}" == "./" ]]; then
                        continue
                    fi
                    if [[ "${file_type}" == "d" ]]; then
                        echo "[updated-dir] ${path}"
                    else
                        changed_paths+=("${path}")
                        echo "[copied] ${path}"
                    fi
                    ;;
                *)
                    echo "${line}"
                    ;;
            esac
            continue
        fi

        echo "${line}"
    done < "${dry_run_file}"

    while IFS= read -r rel_path || [[ -n "${rel_path}" ]]; do
        [[ -n "${rel_path}" ]] || continue
        if path_is_generated_cache "${rel_path}"; then
            continue
        fi
        if path_is_excluded_payload_file "${rel_path}"; then
            continue
        fi
        if path_is_preserved "${rel_path}"; then
            continue
        fi
        if [[ ${#changed_paths[@]} -gt 0 ]] && path_in_list "${rel_path}" "${changed_paths[@]}"; then
            continue
        fi
        echo "[unchanged] ${rel_path}"
    done < <(
        cd "${SOURCE_DIR}" && find . -type f -print \
            | sed 's#^\./##' \
            | LC_ALL=C sort
    )
}

if [[ ! -d "${SOURCE_DIR}" ]]; then
    echo "Missing source directory: ${SOURCE_DIR}"
    exit 1
fi

require_project_dir
mkdir -p "${TARGET_DIR}"
SOURCE_DIR="$(cd "${SOURCE_DIR}" && pwd -P)"
TARGET_DIR="$(cd "${TARGET_DIR}" && pwd -P)"

if ! command -v rsync >/dev/null 2>&1; then
    echo "Required command not found: rsync"
    exit 1
fi

if [[ "${SOURCE_DIR}" == "${TARGET_DIR}" ]]; then
    echo "Source and target directories must be different."
    exit 1
fi

for dir_name in "${STATIC_PRESERVE_IF_PRESENT[@]}"; do
    if [[ -d "${TARGET_DIR}/${dir_name}" ]]; then
        add_preserved_dir "${dir_name}"
    fi
done

shopt -s nullglob
for dir_path in "${TARGET_DIR}"/*; do
    [[ -d "${dir_path}" ]] || continue
    dir_name="$(basename "${dir_path}")"
    if [[ "${dir_name}" =~ ${PRESERVE_PROJECT_DIR_REGEX} ]]; then
        add_preserved_dir "${dir_name}"
    fi
done
shopt -u nullglob

DRY_RUN_FILE="$(make_temp_file)"
cleanup() {
    rm -f "${DRY_RUN_FILE}"
}
trap cleanup EXIT

echo "Source: ${SOURCE_DIR}/"
echo "Target: ${TARGET_DIR}/"
echo "Preserving local project directories matching ${PRESERVE_PROJECT_DIR_DISPLAY}"
for dir_name in "${STATIC_PRESERVE_IF_PRESENT[@]}"; do
    if [[ ${#PRESERVED_DIR_NAMES[@]} -gt 0 ]] && path_in_list "${dir_name}" "${PRESERVED_DIR_NAMES[@]}"; then
        echo "Preserving local directory /${dir_name}/"
    fi
done
echo "Starting sync..."

rsync -ani --delete \
    "${RSYNC_EXCLUDES[@]}" \
    "${SOURCE_DIR}/" "${TARGET_DIR}/" \
    > "${DRY_RUN_FILE}"

if [[ -s "${DRY_RUN_FILE}" ]]; then
    rsync -a --delete \
        "${RSYNC_EXCLUDES[@]}" \
        "${SOURCE_DIR}/" "${TARGET_DIR}/"
fi

helper_copy="${TARGET_DIR}/Extras/pullh20"
if [[ -f "${helper_copy}" || -L "${helper_copy}" ]]; then
    rm -f "${helper_copy}"
    echo "[deleted] Extras/pullh20"
fi

report_sync_results "${DRY_RUN_FILE}"

current_timestamp() {
    local timestamp=""
    local offset=""

    timestamp="$(date '+%Y-%m-%dT%H:%M:%S')"
    offset="$(date '+%z')"
    if [[ "${offset}" =~ ^([+-][0-9][0-9])([0-9][0-9])$ ]]; then
        offset="${BASH_REMATCH[1]}:${BASH_REMATCH[2]}"
    fi

    printf '%s%s\n' "${timestamp}" "${offset}"
}

completed_at="$(current_timestamp)"
echo "Synced ${SOURCE_DIR}/ -> ${TARGET_DIR}/"
echo "Completed at: ${completed_at}"
