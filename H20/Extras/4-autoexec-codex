#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
H20_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECT_ROOT="$(cd "$H20_DIR/.." && pwd)"
EXECUTOR_PROMPT="$H20_DIR/4-execute-step.md"

RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
BLUE=$'\033[34m'
MAGENTA=$'\033[35m'
CYAN=$'\033[36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'

MILESTONE=""
MODEL=""
STEP_LIMIT=0
SKIP_HUMAN=0
DRY_RUN=0

usage() {
    cat <<EOF
${BOLD}${CYAN}4-autoexec-codex${RESET} ${DIM}(optional H20 extra; Codex-specific)${RESET}

${BOLD}Purpose${RESET}
  Execute the next pending H20 step(s) for one milestone by re-running Codex
  headlessly in a loop. This uses the current user's Codex login
  (ChatGPT or API key).

${BOLD}Syntax${RESET}
  ${GREEN}./H20/Extras/4-autoexec-codex${RESET} ${YELLOW}--milestone${RESET} ${MAGENTA}./H20/01-my-feature${RESET} [${YELLOW}--steps${RESET} ${MAGENTA}N${RESET}] [${YELLOW}--model${RESET} ${MAGENTA}<model-id>${RESET}] [${YELLOW}--skiphuman${RESET}] [${YELLOW}--dry-run${RESET}]
  milestone path may be passed as ${MAGENTA}./H20/01-my-feature${RESET} or ${MAGENTA}./01-my-feature${RESET}

${BOLD}Parameter defaults${RESET}
  ${YELLOW}--milestone${RESET}: required; no default
  ${YELLOW}--steps${RESET}: run all pending steps
  ${YELLOW}--model${RESET}: use your local Codex CLI default
  ${YELLOW}--skiphuman${RESET}: omitted by default, so human-only checks stop and hand off
  ${YELLOW}--dry-run${RESET}: omitted by default, so live execution runs
  current tested explicit model: ${MAGENTA}gpt-5.4${RESET}

${BOLD}Examples${RESET}
  ${GREEN}./H20/Extras/4-autoexec-codex${RESET} ${YELLOW}--milestone${RESET} ${MAGENTA}./H20/01-my-feature${RESET}
  ${GREEN}./H20/Extras/4-autoexec-codex${RESET} ${YELLOW}--milestone${RESET} ${MAGENTA}./H20/01-my-feature${RESET} ${YELLOW}--steps${RESET} ${MAGENTA}2${RESET}
  ${GREEN}./H20/Extras/4-autoexec-codex${RESET} ${YELLOW}--milestone${RESET} ${MAGENTA}./H20/01-my-feature${RESET} ${YELLOW}--model${RESET} ${MAGENTA}gpt-5.4${RESET}
  ${GREEN}./H20/Extras/4-autoexec-codex${RESET} ${YELLOW}--milestone${RESET} ${MAGENTA}./H20/01-my-feature${RESET} ${YELLOW}--skiphuman${RESET}
  ${GREEN}./H20/Extras/4-autoexec-codex${RESET} ${YELLOW}--milestone${RESET} ${MAGENTA}./H20/01-my-feature${RESET} ${YELLOW}--dry-run${RESET}

${BOLD}Behavior${RESET}
  ${GREEN}Codex progress output uses the CLI defaults${RESET}
  ${GREEN}approval prompts are disabled via -a never${RESET}
  ${GREEN}sandbox defaults to --sandbox danger-full-access${RESET}
  ${GREEN}runs are ephemeral by default${RESET}
  ${GREEN}--dry-run prints the live-mode milestone and selected steps without launching Codex${RESET}
  ${GREEN}capability requests are handled non-interactively via AUTOEXEC_MODE=1${RESET}
  ${GREEN}BLOCKED.md stops the loop immediately${RESET}
  ${GREEN}missing done-file after a run is treated as a handoff / stop${RESET}

${BOLD}Human verification${RESET}
  without ${YELLOW}--skiphuman${RESET}: stop and hand off when a human-only check is reached
  with    ${YELLOW}--skiphuman${RESET}: pass AUTOEXEC_SKIP_HUMAN=1 and force those checks to be recorded as skipped
EOF
}

note() {
    printf "%s%s%s\n" "$BLUE" "$1" "$RESET"
}

warn() {
    printf "%s%s%s\n" "$YELLOW" "$1" "$RESET"
}

fail() {
    printf "%s%s%s\n" "$RED" "$1" "$RESET" >&2
    exit 1
}

normalize_model() {
    case "$MODEL" in
        gpt-5-codex)
            warn "${BOLD}Model alias gpt-5-codex is no longer accepted by ChatGPT-backed Codex CLI${RESET}${YELLOW} — using gpt-5.4 instead${RESET}"
            MODEL="gpt-5.4"
            ;;
    esac
}

require_command() {
    local cmd="$1"
    command -v "$cmd" >/dev/null 2>&1 || fail "Missing required command: $cmd"
}

abs_path() {
    local target="$1"
    python3 - "$target" <<'PY'
import os
import sys
print(os.path.abspath(sys.argv[1]))
PY
}

resolve_milestone_path() {
    local target="$1"
    local trimmed="${target#./}"
    if [[ -d "$target" ]]; then
        abs_path "$target"
        return 0
    fi
    if [[ -d "$H20_DIR/$trimmed" ]]; then
        abs_path "$H20_DIR/$trimmed"
        return 0
    fi
    return 1
}

step_done_file() {
    local step="$1"
    local base num dir
    base="$(basename "$step")"
    dir="$(dirname "$step")"
    if [[ "$base" =~ ^STEP-([0-9][0-9])--.*\.md$ ]]; then
        num="${BASH_REMATCH[1]}"
        printf "%s/STEP-%s--DONE.md\n" "$dir" "$num"
        return 0
    fi
    return 1
}

next_pending_step() {
    local milestone="$1"
    local step done
    while IFS= read -r step; do
        done="$(step_done_file "$step")" || continue
        if [[ ! -f "$done" ]]; then
            printf "%s\n" "$step"
            return 0
        fi
    done < <(find "$milestone" -maxdepth 1 -type f -name 'STEP-[0-9][0-9]--*.md' ! -name 'STEP-[0-9][0-9]--DONE.md' | sort)
    return 1
}

selected_pending_steps() {
    local milestone="$1"
    local limit="$2"
    local count=0 step done
    while IFS= read -r step; do
        done="$(step_done_file "$step")" || continue
        if [[ ! -f "$done" ]]; then
            printf "%s\n" "$step"
            count=$((count + 1))
            if [[ "$limit" -gt 0 && "$count" -ge "$limit" ]]; then
                return 0
            fi
        fi
    done < <(find "$milestone" -maxdepth 1 -type f -name 'STEP-[0-9][0-9]--*.md' ! -name 'STEP-[0-9][0-9]--DONE.md' | sort)
}

build_prompt() {
    local step="$1"
    cat "$EXECUTOR_PROMPT"
    printf "\n%s\n" "$step"
    printf "AUTOEXEC_MODE=1\n"
    if [[ "$SKIP_HUMAN" -eq 1 ]]; then
        printf "AUTOEXEC_SKIP_HUMAN=1\n"
    fi
}

dry_run_preview() {
    local count=0 step done

    echo "${BOLD}${CYAN}Autoexec dry run${RESET}"
    echo "  agent: codex"
    echo "  mode: preview only; no agent launch; no files written"
    echo "  milestone: $MILESTONE"
    if [[ -n "$MODEL" ]]; then
        echo "  model: $MODEL"
    else
        echo "  model: Codex CLI default"
    fi
    if [[ "$STEP_LIMIT" -eq 0 ]]; then
        echo "  steps: all pending steps"
    else
        echo "  steps: next $STEP_LIMIT step(s)"
    fi
    if [[ "$SKIP_HUMAN" -eq 1 ]]; then
        echo "  human checks: force-skip"
    else
        echo "  human checks: stop and hand off"
    fi
    echo "  approvals: never"
    echo "  sandbox: danger-full-access"
    echo "  session persistence: ephemeral"
    echo "  workspace root: $PROJECT_ROOT"

    if [[ -f "$BLOCKED_FILE" ]]; then
        warn ""
        warn "${BOLD}BLOCKED.md exists${RESET}${YELLOW} — live mode would stop before any autoexec run${RESET}"
        printf "  %s\n" "$BLOCKED_FILE"
        return 0
    fi

    echo ""
    echo "${BOLD}${MAGENTA}Steps live mode would attempt${RESET}"
    while IFS= read -r step; do
        done="$(step_done_file "$step")" || fail "Could not derive done-file for step: $step"
        count=$((count + 1))
        printf "  %s. step: %s\n" "$count" "$step"
        printf "     expected done-file: %s\n" "$done"
    done < <(selected_pending_steps "$MILESTONE" "$STEP_LIMIT")

    if [[ "$count" -eq 0 ]]; then
        echo "  none"
    else
        echo ""
        echo "  live mode still stops early if a step exits unsuccessfully, writes BLOCKED.md, or returns without the expected done-file."
    fi
}

run_codex_for_step() {
    local prompt="$1"
    local -a cmd
    cmd=(codex -a never exec --sandbox danger-full-access --ephemeral --skip-git-repo-check --cd "$PROJECT_ROOT")
    if [[ -n "$MODEL" ]]; then
        cmd+=(--model "$MODEL")
    fi
    cmd+=(-)

    if ! printf "%s" "$prompt" | "${cmd[@]}"; then
        return 1
    fi
}

if [[ "$#" -eq 0 ]]; then
    usage
    exit 0
fi

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        --milestone)
            [[ "$#" -ge 2 ]] || fail "Expected a path after --milestone"
            MILESTONE="$2"
            shift 2
            ;;
        --steps)
            [[ "$#" -ge 2 ]] || fail "Expected a number after --steps"
            STEP_LIMIT="$2"
            [[ "$STEP_LIMIT" =~ ^[1-9][0-9]*$ ]] || fail "--steps expects a positive integer"
            shift 2
            ;;
        --model)
            [[ "$#" -ge 2 ]] || fail "Expected a model after --model"
            MODEL="$2"
            shift 2
            ;;
        --skiphuman)
            SKIP_HUMAN=1
            shift
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            fail "Unknown argument: $1"
            ;;
    esac
done

[[ -n "$MILESTONE" ]] || {
    usage
    exit 0
}

require_command python3

normalize_model

MILESTONE="$(resolve_milestone_path "$MILESTONE")" || fail "Milestone directory not found: $MILESTONE"
[[ -f "$EXECUTOR_PROMPT" ]] || fail "Executor prompt not found: $EXECUTOR_PROMPT"

BLOCKED_FILE="$MILESTONE/BLOCKED.md"
if [[ "$DRY_RUN" -eq 1 ]]; then
    dry_run_preview
    exit 0
fi

require_command codex

if [[ -f "$BLOCKED_FILE" ]]; then
    warn "${BOLD}BLOCKED.md already exists${RESET}${YELLOW} — stopping before any autoexec run${RESET}"
    printf "  %s\n" "$BLOCKED_FILE"
    exit 1
fi

START_TS="$(date +%s)"
RUNS=0

echo "${BOLD}${CYAN}Autoexec${RESET}"
echo "  agent: codex"
echo "  milestone: $MILESTONE"
if [[ -n "$MODEL" ]]; then
    echo "  model: $MODEL"
else
    echo "  model: Codex CLI default"
fi
if [[ "$STEP_LIMIT" -eq 0 ]]; then
    echo "  steps: all pending steps"
else
    echo "  steps: next $STEP_LIMIT step(s)"
fi
if [[ "$SKIP_HUMAN" -eq 1 ]]; then
    echo "  human checks: force-skip"
else
    echo "  human checks: stop and hand off"
fi
echo "  approvals: never"
echo "  sandbox: danger-full-access"
echo "  session persistence: ephemeral"
echo "  workspace root: $PROJECT_ROOT"

while true; do
    if [[ -f "$BLOCKED_FILE" ]]; then
        warn ""
        warn "${BOLD}BLOCKED.md detected${RESET}${YELLOW} — loop stopped${RESET}"
        printf "  %s\n" "$BLOCKED_FILE"
        exit 1
    fi

    if [[ "$STEP_LIMIT" -gt 0 && "$RUNS" -ge "$STEP_LIMIT" ]]; then
        break
    fi

    STEP="$(next_pending_step "$MILESTONE" || true)"
    if [[ -z "${STEP:-}" ]]; then
        break
    fi

    DONE_FILE="$(step_done_file "$STEP")" || fail "Could not derive done-file for step: $STEP"
    RUNS=$((RUNS + 1))

    echo ""
    echo "${BOLD}${MAGENTA}Step $RUNS${RESET}"
    echo "  executing: $STEP"
    echo "  expecting: $DONE_FILE"

    PROMPT="$(build_prompt "$STEP")"
    if ! run_codex_for_step "$PROMPT"; then
        warn ""
        warn "${BOLD}Codex exited unsuccessfully${RESET}${YELLOW} — stopping for inspection${RESET}"
        exit 1
    fi

    if [[ -f "$BLOCKED_FILE" ]]; then
        warn ""
        warn "${BOLD}Step wrote BLOCKED.md${RESET}${YELLOW} — stopping${RESET}"
        printf "  %s\n" "$BLOCKED_FILE"
        exit 1
    fi

    if [[ -f "$DONE_FILE" ]]; then
        note ""
        note "${BOLD}Done-file written${RESET}${BLUE} — continuing${RESET}"
        printf "  %s\n" "$DONE_FILE"
        continue
    fi

    warn ""
    warn "${BOLD}No done-file was written${RESET}${YELLOW} — treating this as a handoff / manual stop${RESET}"
    printf "  step: %s\n" "$STEP"
    printf "  expected done-file: %s\n" "$DONE_FILE"
    if [[ "$SKIP_HUMAN" -eq 0 ]]; then
        printf "  likely cause: human verification or another manual intervention point\n"
    fi
    exit 1
done

ELAPSED=$(( $(date +%s) - START_TS ))

echo ""
echo "${BOLD}${GREEN}Autoexec complete${RESET}"
echo "  executed steps: $RUNS"
if [[ -n "$(next_pending_step "$MILESTONE" || true)" ]]; then
    echo "  milestone status: pending steps remain"
else
    echo "  milestone status: no pending steps remain"
fi
echo "  elapsed seconds: $ELAPSED"
