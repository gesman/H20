#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FORMATTER="$SCRIPT_DIR/stream-formatter.py"

require_command() {
    local cmd="$1"
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Missing required command: $cmd" >&2
        exit 1
    fi
}

if [[ ! -f "$FORMATTER" ]]; then
    echo "Missing formatter: $FORMATTER" >&2
    exit 1
fi

require_command claude
require_command python3

claude --print \
    --output-format stream-json \
    --verbose \
    --include-partial-messages \
    "$@" \
    | python3 "$FORMATTER"
